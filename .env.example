# Clash 外部控制器（容器访问宿主机；Windows 上 exporter 若在本机跑见 .env.windows.example）
# Docker Desktop / Compose 一般会配好 host.docker.internal；纯 Linux 见 README。
CLASH_HOST=host.docker.internal:9090
# CLASH_TOKEN=

EXPORTER_PORT=2112
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Windows：Exporter 在宿主机、仅用合并文件 docker-compose.windows.yml 时，见 .env.windows.example 中 PROMETHEUS_CONFIG_FILE
# PROMETHEUS_CONFIG_FILE=./deploy/prometheus/prometheus.windows.yml

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# 浏览器打开 Grafana 时用的根 URL（本机默认即可）
GRAFANA_ROOT_URL=http://localhost:3000
